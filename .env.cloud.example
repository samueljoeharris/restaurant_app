# Paste this entire file into Cursor → Cloud Agents → Environment variables (.env)
# Fill in the <paste-…> placeholders, then save. Never commit the filled copy.
#
# Where to get values:
#   Maps web key:  gcloud secrets versions access latest --secret=ttf-maps-web-api-key --project=ttf-restaurant-dev
#   Maps API key:  gcloud secrets versions access latest --secret=ttf-maps-api-key --project=ttf-restaurant-dev
#   Firebase web:  gcloud secrets versions access latest --secret=ttf-firebase-web-env --project=ttf-restaurant-dev
#   GitHub PAT:    github.com → Settings → Developer settings → Fine-grained tokens (repo + Actions)

# ── GitHub MCP + workflow dispatch ───────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=<paste-github-pat>

# ── Maps (required for /map) ─────────────────────────────────────────────────
MAPS_API_KEY=<paste-server-places-key>
VITE_GOOGLE_MAPS_API_KEY=<paste-browser-maps-js-key>

# ── Local docker compose API ─────────────────────────────────────────────────
DATABASE_URL=postgresql://ttf_app:ttf_local@localhost:5432/ttf
POSTGRES_CONNECTION_STRING=postgresql://ttf_app:ttf_local@localhost:5432/ttf
PILOT_CITY=dedham-ma
PILOT_DISPLAY_NAME=Little Scout
AUTH_DEV_MODE=true
FIREBASE_AUTH_EMULATOR_HOST=firebase-emulator:9099
FIREBASE_PROJECT_ID=ttf-restaurant-dev
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-sa.json
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
TTF_GCP_PROJECT_DEV=ttf-restaurant-dev

# ── Web Vite (local npm run dev) ─────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
VITE_USE_AUTH_EMULATOR=true
VITE_FIREBASE_API_KEY=fake-api-key-for-emulator
VITE_FIREBASE_AUTH_DOMAIN=localhost
VITE_FIREBASE_PROJECT_ID=ttf-restaurant-dev
VITE_FIREBASE_APP_ID=
VITE_ENABLE_REVIEW_CHAT=true

# ── Browser testing on app.dev (real Firebase — not the emulator user) ─────────
DEV_TEST_EMAIL=<your-dev-firebase-email>
DEV_TEST_PASSWORD=<your-dev-firebase-password>

# ── Optional ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}  # one line; or leave empty + echo '{}' > firebase-sa.json
