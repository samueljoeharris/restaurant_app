# Copy to .env and fill in values. .env is gitignored — never commit secrets.
#
#   cp .env.example .env
#
# Then restart Cursor (or Reload Window) so MCP servers pick up changes.

# GitHub MCP (fine-grained PAT named ttf-cursor-mcp, scoped to restaurant_app)
GITHUB_PERSONAL_ACCESS_TOKEN=

# Postgres MCP (Phase 2 — when docker compose postgres is running)
POSTGRES_CONNECTION_STRING=postgresql://ttf_app:ttf_local@localhost:5432/ttf

# Optional — reference for gcloud CLI / scripts
TTF_GCP_PROJECT_DEV=ttf-restaurant-dev
