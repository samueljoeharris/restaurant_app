# Copy to .env and fill in values. .env is gitignored — never commit secrets.
#
#   cp .env.example .env
#
# Then restart Cursor (or Reload Window) so MCP servers pick up changes.

# GitHub MCP (fine-grained PAT named ttf-cursor-mcp, scoped to restaurant_app)
GITHUB_PERSONAL_ACCESS_TOKEN=

# Postgres MCP (when docker compose postgres is running)
POSTGRES_CONNECTION_STRING=postgresql://ttf_app:ttf_local@localhost:5432/ttf

# API (docker compose api — host uses localhost, container uses postgres hostname)
DATABASE_URL=postgresql://ttf_app:ttf_local@localhost:5432/ttf
# Opaque catalog key for the shared restaurant set (not a geographic limit).
PILOT_CITY=dedham-ma
PILOT_DISPLAY_NAME=Little Scout
MAPS_API_KEY=
# Gemini Developer API key for server-side review chat (never exposed to browsers)
GEMINI_API_KEY=
# Optional overrides — defaults: gemini-2.5-flash-lite (chat), gemini-2.5-flash (structured extract)
# GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
# GEMINI_EXTRACT_MODEL=gemini-2.5-flash
# Neutral fallback center for scheduled refresh when no seed areas exist yet.
RESTAURANT_SEED_DEFAULT_LAT=42.2418
RESTAURANT_SEED_DEFAULT_LNG=-71.1662
RESTAURANT_SEED_DEFAULT_RADIUS_M=8000
RESTAURANT_SEED_COOLDOWN_HOURS=24
RESTAURANT_SEED_REFRESH_QUERIES=["restaurants","family restaurants","pizza","breakfast"]

# Firebase Auth — see docs/FIREBASE_AUTH.md
FIREBASE_PROJECT_ID=ttf-restaurant-dev
# Dev tokens: Bearer dev:<uid> (disable in production)
AUTH_DEV_MODE=true
# Comma-separated UIDs treated as admin when using dev: tokens locally
# AUTH_DEV_ADMIN_UIDS=your-firebase-uid
# Set by docker-compose when using firebase-emulator service
# FIREBASE_AUTH_EMULATOR_HOST=firebase-emulator:9099
# Production Firebase JWT verify (local API with web app sign-in)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-sa.json
# Emulator mode: docker compose --profile emulator up … and uncomment:
# FIREBASE_AUTH_EMULATOR_HOST=firebase-emulator:9099
# Web pilot CORS (JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Optional — reference for gcloud CLI / scripts
TTF_GCP_PROJECT_DEV=ttf-restaurant-dev

# Terraform docker compose — gcloud ADC mount (Mac/Linux default: ~/.config/gcloud)
# Windows Docker Desktop example:
# GCLOUD_CONFIG_PATH=C:/Users/You/AppData/Roaming/gcloud
