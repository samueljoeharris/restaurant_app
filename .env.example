# Copy to .env and fill in values. .env is gitignored — never commit secrets.
#
#   cp .env.example .env
#
# Then restart Cursor (or Reload Window) so MCP servers pick up changes.

# GitHub MCP (fine-grained PAT named ttf-cursor-mcp, scoped to restaurant_app)
GITHUB_PERSONAL_ACCESS_TOKEN=

# Postgres MCP (when docker compose postgres is running)
POSTGRES_CONNECTION_STRING=postgresql://ttf_app:ttf_local@localhost:5432/ttf

# API (docker compose api — host uses localhost, container uses postgres hostname)
DATABASE_URL=postgresql://ttf_app:ttf_local@localhost:5432/ttf
PILOT_CITY=dedham-ma
PILOT_DISPLAY_NAME=Dedham, Massachusetts
MAPS_API_KEY=

# Firebase Auth — see docs/FIREBASE_AUTH.md
FIREBASE_PROJECT_ID=ttf-restaurant-dev
# Dev tokens: Bearer dev:<uid> (disable in production)
AUTH_DEV_MODE=true
# Set by docker-compose when using firebase-emulator service
# FIREBASE_AUTH_EMULATOR_HOST=firebase-emulator:9099
# Production: download from Firebase Console → Service accounts
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-sa.json
# Web pilot CORS (JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Optional — reference for gcloud CLI / scripts
TTF_GCP_PROJECT_DEV=ttf-restaurant-dev
