# Cursor Cloud Agents → Environment variables (VISIBLE to the agent)
# Non-sensitive config only. Copy into Cursor settings as Environment Variables.
# Sensitive keys → Runtime Secrets (see docs/CLOUD_AGENT.md). Never commit filled copy.

DATABASE_URL=postgresql://ttf_app:ttf_local@localhost:5432/ttf
POSTGRES_CONNECTION_STRING=postgresql://ttf_app:ttf_local@localhost:5432/ttf
PILOT_CITY=dedham-ma
PILOT_DISPLAY_NAME=Little Scout
FIREBASE_PROJECT_ID=ttf-restaurant-dev
AUTH_DEV_MODE=true
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-sa.json
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
TTF_GCP_PROJECT_DEV=ttf-restaurant-dev

# Real Firebase web (matches app.dev / local web/.env.local)
VITE_API_URL=http://localhost:8080
VITE_FIREBASE_AUTH_DOMAIN=ttf-restaurant-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ttf-restaurant-dev
VITE_ENABLE_REVIEW_CHAT=true

# Do NOT set FIREBASE_AUTH_EMULATOR_HOST or VITE_USE_AUTH_EMULATOR for real Firebase.
