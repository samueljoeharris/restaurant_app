{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Quicksand|Nunito))/i]",
        "message": "Font not provided by the design system. Available: Quicksand, Nunito."
      },
      {
        "selector": "JSXOpeningElement[name.name='AttributeChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|active|dashed|key|ref|className|style|children)$/]",
        "message": "<AttributeChip> doesn't accept that prop. Declared props: label, icon, active, dashed."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|brand|success|warning|error|accent)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'brand' | 'success' | 'warning' | 'error' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomNavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|active|onClick|key|ref|className|style|children)$/]",
        "message": "<BottomNavItem> doesn't accept that prop. Declared props: icon, label, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|soft|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'soft' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|helper|error|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, helper, error, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='RestaurantListCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|address|ttfMinutes|ttfTier|ttfLabel|badges|watched|active|density|onSelect|onWatch|style|key|ref|className|style|children)$/]",
        "message": "<RestaurantListCard> doesn't accept that prop. Declared props: name, address, ttfMinutes, ttfTier, ttfLabel, badges, watched, active, density, onSelect, onWatch, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RestaurantListCard'] > JSXAttribute[name.name='ttfTier'] > Literal[value!=/^(?:fast|ok|slow|none)$/]",
        "message": "<RestaurantListCard> ttfTier must be one of 'fast' | 'ok' | 'slow' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RestaurantListCard'] > JSXAttribute[name.name='density'] > Literal[value!=/^(?:default|compact)$/]",
        "message": "<RestaurantListCard> density must be one of 'default' | 'compact'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeedBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:minutes|tier|caption|meta|style|key|ref|className|style|children)$/]",
        "message": "<SpeedBadge> doesn't accept that prop. Declared props: minutes, tier, caption, meta, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeedBadge'] > JSXAttribute[name.name='tier'] > Literal[value!=/^(?:fast|ok|slow|none)$/]",
        "message": "<SpeedBadge> tier must be one of 'fast' | 'ok' | 'slow' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|style|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: checked, onChange, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='UpdateCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|tier|time|isNew|children|key|ref|className|style|children)$/]",
        "message": "<UpdateCard> doesn't accept that prop. Declared props: name, tier, time, isNew, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='UpdateCard'] > JSXAttribute[name.name='tier'] > Literal[value!=/^(?:fast|ok|slow|none)$/]",
        "message": "<UpdateCard> tier must be one of 'fast' | 'ok' | 'slow' | 'none'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
