# Copy to .env.local only for offline/emulator dev without GCP access.
# Normal workflow: ./scripts/sync-secrets.sh → generates web/.env.local from Secret Manager.
#
#   cp web/.env.example web/.env.local   # emulator / offline only

VITE_FIREBASE_AUTH_DOMAIN=ttf-restaurant-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ttf-restaurant-dev
VITE_API_URL=http://localhost:8080
VITE_ENABLE_REVIEW_CHAT=true

# Secrets (VITE_FIREBASE_API_KEY, VITE_GOOGLE_MAPS_API_KEY) come from sync-secrets.sh
