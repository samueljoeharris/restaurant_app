# Copy to .env.local (gitignored via Vite convention)
#
# Firebase Web SDK — Project settings → Your apps → Web app → SDK snippet
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=ttf-restaurant-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ttf-restaurant-dev

# API base URL (local or Cloud Run)
# Dev API (after DNS): https://api.dev.littlescout.app
VITE_API_URL=https://ttf-api-6ac5e3cakq-uc.a.run.app

# Google Maps JavaScript API (browser key — Maps JavaScript API enabled)
# Create a separate key from the server Places/Geocoding key; HTTP referrer restrict.
# VITE_GOOGLE_MAPS_API_KEY=

# App Check (reCAPTCHA Enterprise site key — optional for local dev)
# VITE_APP_CHECK_RECAPTCHA_SITE_KEY=
# VITE_APP_CHECK_ENABLED=false
